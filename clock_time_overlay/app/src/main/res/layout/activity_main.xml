<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#10151B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="#1C2833"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clock Time Overlay"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Floating real-time helper for manual clock changes"
            android:textSize="16sp"
            android:textColor="#AAB7C4"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:elevation="8dp"
                android:radius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#22313F">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overlay Control"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start the floating clock widget or change the minute step."
                        android:textSize="14sp"
                        android:textColor="#AAB7C4"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp" />

                    <Button
                        android:id="@+id/startOverlayButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="Start Clock Overlay"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E8B57" />

                    <Button
                        android:id="@+id/settingsButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="Clock Step Settings"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1F6AA5"
                        android:layout_marginTop="12dp" />

                    <Button
                        android:id="@+id/stopOverlayButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="Stop Clock Overlay"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B23A48"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="8dp"
                android:radius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#22313F">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How It Works"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Set the minute step in Settings.\n\n2. Start the overlay and grant draw-over-apps permission.\n\n3. The overlay shows the current device time and the target time after one step.\n\n4. Tap + to open Android Date &amp; Time settings and manually move the device clock forward by that amount.\n\n5. Tap Auto to open Date &amp; Time settings and turn automatic time back on.\n\n6. Tap X to close the overlay or drag it anywhere."
                        android:textSize="15sp"
                        android:textColor="#AAB7C4"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginTop="16dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
